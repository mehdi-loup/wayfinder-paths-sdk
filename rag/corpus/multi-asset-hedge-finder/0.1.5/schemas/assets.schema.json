{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "assets",
  "type": "object",
  "required": ["holdings"],
  "properties": {
    "holdings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["symbol", "notional_usd"],
        "properties": {
          "symbol": { "type": "string", "minLength": 1 },
          "notional_usd": { "type": "number", "exclusiveMinimum": 0 },
          "side": { "type": "string", "enum": ["long", "short"], "default": "long" },
          "chain": { "type": "string" },
          "venue": { "type": "string" },
          "token_address": { "type": "string" }
        }
      }
    }
  }
}
